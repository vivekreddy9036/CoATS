# ═══════════════════════════════════════════════════════════════════════════════
# CoATS Hyperledger Fabric Network — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
#
# SECURITY: Never commit the real .env file. This is a template only.
#           Generate strong passwords during setup with: openssl rand -hex 32
#
# Copy this file:  cp .env.example .env
# Then fill in all <GENERATE_...> placeholders.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Fabric Image Versions ──────────────────────────────────────────────────
FABRIC_VERSION=2.5
FABRIC_CA_VERSION=1.5

# ─── Docker Compose ─────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=coats-fabric

# ─── Channel & Chaincode ────────────────────────────────────────────────────
CHANNEL_NAME=coats-channel
CHAINCODE_NAME=coats-chaincode
CHAINCODE_VERSION=1.0
CHAINCODE_SEQUENCE=1

# ─── MSP Identifiers ────────────────────────────────────────────────────────
ORDERER_MSP=OrdererMSP
COATS_MSP=CoATSMSP

# ─── Fabric CA — Orderer Org ────────────────────────────────────────────────
# CHANGE IN PRODUCTION: openssl rand -hex 32
CA_ORDERER_ADMIN_USER=admin
CA_ORDERER_ADMIN_PASSWORD=<GENERATE_STRONG_PASSWORD>

# ─── Fabric CA — CoATS Org ──────────────────────────────────────────────────
# CHANGE IN PRODUCTION: openssl rand -hex 32
CA_COATS_ADMIN_USER=admin
CA_COATS_ADMIN_PASSWORD=<GENERATE_STRONG_PASSWORD>

# ─── Identity Passwords (generated during enrollment) ───────────────────────
# These are set by the enrollment script. Do not change manually.
ORDERER_PASSWORD=<GENERATE_STRONG_PASSWORD>
ORDERER_ADMIN_PASSWORD=<GENERATE_STRONG_PASSWORD>
PEER0_PASSWORD=<GENERATE_STRONG_PASSWORD>
COATS_ADMIN_PASSWORD=<GENERATE_STRONG_PASSWORD>
COATS_CLIENT_PASSWORD=<GENERATE_STRONG_PASSWORD>

# ─── CouchDB (State Database) ──────────────────────────────────────────────
# CHANGE IN PRODUCTION: openssl rand -hex 24
COUCHDB_USER=coats_statedb
COUCHDB_PASSWORD=<GENERATE_STRONG_PASSWORD>

# ─── Ports (Host Bindings) ──────────────────────────────────────────────────
ORDERER_PORT=7050
ORDERER_ADMIN_PORT=7053
PEER0_PORT=7051
PEER0_CHAINCODE_PORT=7052
CA_ORDERER_PORT=7054
CA_COATS_PORT=8054

# ─── External Access ────────────────────────────────────────────────────────
# Set to your GCP VM's external IP or DNS name.
# Used in TLS certificate SAN for external gRPC connections.
EXTERNAL_HOST=<YOUR_GCP_VM_EXTERNAL_IP>
