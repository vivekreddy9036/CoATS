# ─── Database ───────────────────────────────────────
# Replace with your actual database connection strings
DATABASE_URL="YOUR_DATABASE_URL_HERE"
DIRECT_DATABASE_URL="YOUR_DIRECT_DATABASE_URL_HERE"

# ─── JWT ────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="YOUR_JWT_SECRET_HERE"

# ─── TOTP 2FA Encryption ───────────────────────────
# 64-char hex string (32 bytes). Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOTP_ENCRYPTION_KEY="YOUR_64_CHAR_HEX_KEY_HERE"

# ─── Cloudflare Turnstile ───────────────────────
# Local dev: use Cloudflare test keys (always pass): site=1x00000000000000000000AA secret=1x0000000000000000000000000000000AA
# Production: replace with real keys from Cloudflare dashboard
NEXT_PUBLIC_TURNSTILE_SITE_KEY="YOUR_TURNSTILE_SITE_KEY_HERE"
TURNSTILE_SECRET_KEY="YOUR_TURNSTILE_SECRET_KEY_HERE"

# ─── Seed ──────────────────────────────────────────
# Optional: set a default password for seeded users (if unset, a random one is generated)
# SEED_DEFAULT_PASSWORD="YOUR_SEED_PASSWORD_HERE"

# ─── App ────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="CoATS"

# ─── Passkey / WebAuthn ─────────────────────────────
# RP_ID = your domain without protocol/port (e.g. "coats.example.com")
# ORIGIN = full origin the browser sees (e.g. "https://coats.example.com")
WEBAUTHN_RP_ID="localhost"
WEBAUTHN_ORIGIN="http://localhost:3000"

# ─── Hyperledger Fabric ─────────────────────────────────────────────────────
#
# LOCAL DEV — uses cert files from fabric-certs/ folder (works with file system)
# Leave B64 vars empty for local dev.
#
FABRIC_PEER_ENDPOINT="localhost:7051"
FABRIC_PEER_HOSTNAME="peer0.org1.example.com"
FABRIC_CHANNEL="coats-channel"
FABRIC_CHAINCODE="coats-chaincode"
FABRIC_MSP_ID="Org1MSP"
FABRIC_TLS_CERT_PATH="./fabric-certs/tls-ca.crt"
FABRIC_CERT_PATH="./fabric-certs/admin-cert.pem"
FABRIC_KEY_PATH="./fabric-certs/admin-key.pem"
#
# PRODUCTION / VERCEL — Vercel has no filesystem, so certs are stored as
# base64-encoded strings. Generate these values in WSL with:
#
#   base64 -w 0 fabric-certs/tls-ca.crt
#   base64 -w 0 fabric-certs/admin-cert.pem
#   base64 -w 0 fabric-certs/admin-key.pem
#
# Then paste each output as the value below in Vercel Environment Variables.
# Leave PATH vars empty when using B64 vars (B64 takes priority automatically).
#
FABRIC_TLS_CERT_B64=""
FABRIC_CERT_B64=""
FABRIC_KEY_B64=""